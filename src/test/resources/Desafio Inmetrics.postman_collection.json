		{
			"name": "accountservice.war",
			"item": [
				{
					"name": "01 - Register",
					"item": [
						{
							"name": "/accountrest/api/v1/register",
							"item": [
								{
									"name": "Create a new User account",
									"event": [
										{
											"listen": "prerequest",
											"script": {
												"exec": [
													"// Função para gerar senha forte\r",
													"function generateStrongPassword(length = 8) {\r",
													"    const chars = {\r",
													"        lowercase: 'abcdefghijklmnopqrstuvwxyz',\r",
													"        uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',\r",
													"        numbers: '0123456789',\r",
													"        symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?'\r",
													"    };\r",
													"    \r",
													"    let password = '';\r",
													"    // Garante pelo menos 1 caractere de cada tipo\r",
													"    password += chars.lowercase.charAt(Math.floor(Math.random() * chars.lowercase.length));\r",
													"    password += chars.uppercase.charAt(Math.floor(Math.random() * chars.uppercase.length));\r",
													"    password += chars.numbers.charAt(Math.floor(Math.random() * chars.numbers.length));\r",
													"    password += chars.symbols.charAt(Math.floor(Math.random() * chars.symbols.length));\r",
													"    \r",
													"    // Preenche o restante da senha com caracteres aleatórios\r",
													"    const allChars = chars.lowercase + chars.uppercase + chars.numbers + chars.symbols;\r",
													"    for (let i = password.length; i < length; i++) {\r",
													"        password += allChars.charAt(Math.floor(Math.random() * allChars.length));\r",
													"    }\r",
													"    \r",
													"    // Embaralha a senha para não ter padrão fixo\r",
													"    return password.split('').sort(() => 0.5 - Math.random()).join('');\r",
													"}\r",
													"// Gera dados aleatórios para registro\r",
													"function getRandomUser() {\r",
													"    const timestamp = new Date().getTime();\r",
													"    const randomId = Math.floor(Math.random() * 10000);\r",
													"    \r",
													"    let firstName = [\"João\", \"Maria\", \"Carlos\", \"Ana\"][Math.floor(Math.random() * 4)]\r",
													"    let lastName = [\"Silva\", \"Oliveira\", \"Costa\", \"Ferreira\"][Math.floor(Math.random() * 4)]\r",
													"    return {\r",
													"        accountType: \"USER\",\r",
													"        address: `Rua ${randomId}, ${Math.floor(Math.random() * 1000)}`,\r",
													"        allowOffersPromotion: true, // 50% de chance\r",
													"        aobUser: true,\r",
													"        cityName: [\"São Paulo\", \"Rio de Janeiro\", \"Belo Horizonte\", \"Porto Alegre\"][Math.floor(Math.random() * 4)],\r",
													"        country: \"BRAZIL_BR\",\r",
													"        email: lastName + firstName + timestamp.toString().slice(-3) + `@test.com`,\r",
													"        firstName: firstName,\r",
													"        lastName: lastName,\r",
													"        loginName: lastName + firstName + timestamp.toString().slice(-3),\r",
													"        password: generateStrongPassword(), // Senha@1234\r",
													"        phoneNumber: `119${Math.floor(10000000 + Math.random() * 90000000)}`,\r",
													"        stateProvince: [\"SP\", \"RJ\", \"MG\", \"RS\"][Math.floor(Math.random() * 4)],\r",
													"        zipcode: `${Math.floor(10000 + Math.random() * 90000)}000`\r",
													"    };\r",
													"}\r",
													"\r",
													"// Gera e armazena os dados\r",
													"const userData = getRandomUser();\r",
													"pm.collectionVariables.set(\"currentUser\", JSON.stringify(userData));\r",
													"\r",
													"// Define os valores individuais também para fácil acesso\r",
													"Object.keys(userData).forEach(key => {\r",
													"    pm.collectionVariables.set(`user_${key}`, userData[key]);\r",
													"});\r",
													"\r",
													"console.log(\"Novo usuário gerado:\", userData);"
												],
												"type": "text/javascript",
												"packages": {}
											}
										},
										{
											"listen": "test",
											"script": {
												"exec": [
													"pm.test(\"Status code retornou 200\", function () {\r",
													"    pm.response.to.have.status(200);\r",
													"});"
												],
												"type": "text/javascript",
												"packages": {}
											}
										}
									],
									"request": {
										"method": "POST",
										"header": [
											{
												"key": "accept",
												"value": "*/*"
											},
											{
												"key": "Content-Type",
												"value": "application/json"
											}
										],
										"body": {
											"mode": "raw",
											"raw": "{{currentUser}}",
											"options": {
												"raw": {
													"language": "json"
												}
											}
										},
										"url": {
											"raw": "{{baseURL}}/accountservice/accountrest/api/v1/register",
											"host": [
												"{{baseURL}}"
											],
											"path": [
												"accountservice",
												"accountrest",
												"api",
												"v1",
												"register"
											]
										}
									},
									"response": []
								}
							]
						}
					]
				},
				{
					"name": "02 - Login",
					"item": [
						{
							"name": "/accountrest/api/v1/login",
							"item": [
								{
									"name": "Login to AOS",
									"event": [
										{
											"listen": "test",
											"script": {
												"exec": [
													"const resp = pm.response;\r",
													"const response = resp.json().statusMessage;\r",
													"\r",
													"if (response.token) pm.collectionVariables.set(\"token\", response.token);\r",
													"if (response.sessionId) pm.collectionVariables.set(\"userId\", response.userId);\r",
													"\r",
													"pm.test(\"✅ Status code igual a 200\", () => resp.to.have.status(200));\r",
													"\r",
													"pm.test(\"✅ Campos obrigatórios existem\", () => {\r",
													"    const requiredFields = ['success', 'userId', 'reason', 'token', 'sessionId'];\r",
													"    requiredFields.forEach(field => {\r",
													"        pm.expect(response, `Campo '${field}' está faltando`).to.have.property(field);\r",
													"    });\r",
													"});\r",
													"\r",
													"pm.test(\"✅ Tipos e valores estão corretos\", () => {\r",
													"    pm.expect(response.success, \"'success' deve ser true\").to.be.true;\r",
													"    pm.expect(response.userId, \"'userId' deve ser número positivo\").to.be.a('number').and.to.be.above(0);\r",
													"    pm.expect(response.reason, \"'reason' não pode estar vazio\").to.be.a('string').and.not.to.be.empty;\r",
													"    pm.expect(response.token, \"'token' inválido\").to.be.a('string').and.to.match(/^eyJ/);\r",
													"    pm.expect(response.sessionId, \"'sessionId' inválido\").to.be.a('string').and.to.include('@');\r",
													"});"
												],
												"type": "text/javascript",
												"packages": {}
											}
										}
									],
									"request": {
										"method": "POST",
										"header": [
											{
												"key": "accept",
												"value": "*/*"
											},
											{
												"key": "Content-Type",
												"value": "application/json"
											}
										],
										"body": {
											"mode": "raw",
											"raw": "{\n  \"email\": \"{{user_email}}\",\n  \"loginPassword\": \"{{user_password}}\",\n  \"loginUser\": \"{{user_loginName}}\"\n}",
											"options": {
												"raw": {
													"language": "json"
												}
											}
										},
										"url": {
											"raw": "{{baseURL}}/accountservice/accountrest/api/v1/login",
											"host": [
												"{{baseURL}}"
											],
											"path": [
												"accountservice",
												"accountrest",
												"api",
												"v1",
												"login"
											]
										}
									},
									"response": []
								}
							]
						}
					]
				}
			],
			"description": "Modulo de"
